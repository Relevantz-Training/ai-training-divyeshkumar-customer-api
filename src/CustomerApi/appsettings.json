{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "CustomerDatabase": "Data Source=customer.db"
  },
  "Swagger": {
    "EnableInProduction": false
  },
  "Jwt": {
    "Issuer": "CustomerApi",
    "Audience": "CustomerApiClients",
    "SigningKey": "local-dev-signing-key-change-this-value-for-production-12345",
    "TokenLifetimeMinutes": 60
  }
}
